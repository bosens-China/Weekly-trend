# 复制为 .env 后填入（.env 已被 gitignore）
OPENAI_API_KEY=sk-xxxx

# 可选配置
# OPENAI_MODEL=gpt-4o            # 默认 gpt-4o（需支持视觉）
# OPENAI_BASE_URL=               # 走代理/自建网关时填
#
# 接入 OpenAI 兼容的视觉模型示例（小米 MiMo）：
# OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
# OPENAI_MODEL=mimo-v2.5
# README_MAX_CHARS=32000         # README 截断长度（字符），默认 32000
# WEEKLY_CONCURRENCY=8           # 并行处理仓库的线程数，默认 8
# CACHE_TTL_DAYS=30              # 本地缓存有效期（天），默认 30；超期条目加载时自动清理
# GITHUB_TOKEN=                  # 抓 README 提高 API 速率限制（CI 自动注入）
